# ── Postgres (mismo n8n_sql que ever/vicki_chat/hikvsion_get_events) ─────────
DATABASE_URL=postgresql://n8n:3v3rW3ar@n8n_sql:5432/n8n

# ── Gmail / Drive OAuth2 ──────────────────────────────────────────────────────
# Reusar la MISMA credencial OAuth2 que ya tiene autorizada n8n para
# seleccion@everwear.com.ar (n8n > Credentials > Gmail/Google Drive OAuth2 API).
# client_id / client_secret: los de la app OAuth registrada en Google Cloud Console
# que n8n usa (Google Cloud Console > APIs & Services > Credentials).
# refresh_token: hay que generarlo una vez corriendo scripts/get_refresh_token.py
# (o, si n8n permite exportar credenciales, copiar el refresh_token de ahí).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER=seleccion@everwear.com.ar

# ── LLM ────────────────────────────────────────────────────────────────────
