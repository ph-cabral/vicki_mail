ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Qdrant (mismo n8n_qdrant que vicki_chat) ─────────────────────────────────
